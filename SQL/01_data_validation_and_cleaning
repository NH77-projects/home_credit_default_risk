WITH duplicate_cte AS(
	SELECT *, ROW_NUMBER() OVER(PARTITION BY "SK_ID_CURR") AS row_num
	FROM application_train_staging
)
SELECT *
FROM duplicate_cte
WHERE row_num > 1; -- No Duplicates


